generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RoomType {
  text
  announcement
  lightweight_audio
}

enum RoomRole {
  owner
  admin
  moderator
  driver
  voice
  member
  guest
}

enum MessageStatus {
  sent
  edited
  deleted
}

enum PresenceStatus {
  online
  idle
  dnd
  offline
}

model User {
  id                 String            @id @default(uuid()) @db.Uuid
  handle             String            @unique @db.VarChar(32)
  displayName        String            @db.VarChar(80)
  passwordHash       String?           @db.VarChar(256)
  avatarUrl          String?
  locale             String            @default("en")
  globalRole         String            @default("user") // "admin", "moderator", "driver", "voice", "user"
  bannedUntil        DateTime?         @db.Timestamptz(6)
  mutedUntil         DateTime?         @db.Timestamptz(6)
  blockChallenges    Boolean           @default(false)
  blockPMs           Boolean           @default(false)
  customAvatarUrl    String?
  createdAt          DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime          @updatedAt @db.Timestamptz(6)
  sessions           AuthSession[]
  memberships        RoomMember[]
  messages           Message[]
  reactions          Reaction[]
  notifications      Notification[]
  readReceipts       ReadReceipt[]
  auditLogs          AuditLog[]
  points             UserPoints?
  roomPunishments    RoomPunishment[]
  sentPMs            PrivateMessage[]  @relation("SentPMs")
  receivedPMs        PrivateMessage[]  @relation("ReceivedPMs")
  challengerBattles  BattleChallenge[] @relation("Challenger")
  defenderBattles    BattleChallenge[] @relation("Defender")

  @@index([displayName])
  @@map("users")
}

model AuthSession {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  refreshHash  String    @unique @db.VarChar(128)
  userAgent    String?   @db.VarChar(240)
  ipHash       String?   @db.VarChar(128)
  expiresAt    DateTime  @db.Timestamptz(6)
  revokedAt    DateTime? @db.Timestamptz(6)
  rotatedAt    DateTime? @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("auth_sessions")
}

model Room {
  id              String           @id @default(uuid()) @db.Uuid
  slug            String           @unique @db.VarChar(64)
  name            String           @db.VarChar(100)
  type            RoomType         @default(text)
  description     String?          @db.VarChar(240)
  isPrivate       Boolean          @default(false)
  createdById     String           @db.Uuid
  createdAt       DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @db.Timestamptz(6)
  members         RoomMember[]
  messages        Message[]
  threads         Thread[]
  notifications   Notification[]
  readReceipts    ReadReceipt[]
  auditLogs       AuditLog[]
  tournaments     Tournament[]
  roomPunishments RoomPunishment[]

  @@index([type, updatedAt])
  @@map("rooms")
}

model RoomMember {
  id         String   @id @default(uuid()) @db.Uuid
  roomId     String   @db.Uuid
  userId     String   @db.Uuid
  role       RoomRole @default(member)
  canPost    Boolean  @default(true)
  canReact   Boolean  @default(true)
  canModerate Boolean @default(false)
  joinedAt   DateTime @default(now()) @db.Timestamptz(6)
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId, role])
  @@map("room_members")
}

model Thread {
  id              String    @id @default(uuid()) @db.Uuid
  roomId          String    @db.Uuid
  rootMessageId   String    @unique @db.Uuid
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)
  room            Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  rootMessage     Message   @relation("ThreadRoot", fields: [rootMessageId], references: [id], onDelete: Cascade)
  replies         Message[] @relation("ThreadReplies")

  @@index([roomId, updatedAt])
  @@map("threads")
}

model Message {
  id             String        @id @default(uuid()) @db.Uuid
  roomId         String        @db.Uuid
  authorId       String        @db.Uuid
  threadId       String?       @db.Uuid
  parentId       String?       @db.Uuid
  body           String        @db.VarChar(4000)
  status         MessageStatus @default(sent)
  clientNonce    String?       @db.VarChar(80)
  createdAt      DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @db.Timestamptz(6)
  room           Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  author         User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  thread         Thread?       @relation("ThreadReplies", fields: [threadId], references: [id], onDelete: SetNull)
  rootedThread   Thread?       @relation("ThreadRoot")
  reactions      Reaction[]
  readReceipts   ReadReceipt[]
  notifications  Notification[]

  @@unique([authorId, clientNonce])
  @@index([roomId, createdAt])
  @@index([threadId, createdAt])
  @@index([authorId, createdAt])
  @@map("messages")
}

model ReadReceipt {
  id        String   @id @default(uuid()) @db.Uuid
  roomId    String   @db.Uuid
  userId    String   @db.Uuid
  messageId String   @db.Uuid
  readAt    DateTime @default(now()) @db.Timestamptz(6)
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId, messageId])
  @@index([roomId, userId, readAt])
  @@map("read_receipts")
}

model Reaction {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @db.Uuid
  userId    String   @db.Uuid
  emoji     String   @db.VarChar(32)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([userId, createdAt])
  @@map("reactions")
}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  roomId    String?   @db.Uuid
  messageId String?   @db.Uuid
  kind      String    @db.VarChar(40)
  readAt    DateTime? @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  room      Room?     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  message   Message?  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([roomId, createdAt])
  @@map("notifications")
}


model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  actorId   String?  @db.Uuid
  roomId    String?  @db.Uuid
  action    String   @db.VarChar(80)
  metadata  Json?
  ipHash    String?  @db.VarChar(128)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  room      Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([roomId, createdAt])
  @@map("audit_logs")
}

model RoomPunishment {
  id        String   @id @default(uuid()) @db.Uuid
  roomId    String   @db.Uuid
  userId    String   @db.Uuid
  type      String   // "ban", "mute"
  expiresAt DateTime? @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId, type])
  @@map("room_punishments")
}

model PrivateMessage {
  id         String   @id @default(uuid()) @db.Uuid
  senderId   String   @db.Uuid
  receiverId String   @db.Uuid
  body       String   @db.VarChar(4000)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  sender     User     @relation("SentPMs", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedPMs", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId, createdAt])
  @@map("private_messages")
}

model BattleChallenge {
  id           String   @id @default(uuid()) @db.Uuid
  challengerId String   @db.Uuid
  defenderId   String   @db.Uuid
  status       String   // "pending", "accepted", "declined", "completed"
  winnerId     String?  @db.Uuid
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  challenger   User     @relation("Challenger", fields: [challengerId], references: [id], onDelete: Cascade)
  defender     User     @relation("Defender", fields: [defenderId], references: [id], onDelete: Cascade)

  @@map("battle_challenges")
}

model UserPoints {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @unique
  points    Int      @default(0)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_points")
}

model Tournament {
  id        String   @id @default(uuid()) @db.Uuid
  roomId    String   @db.Uuid
  name      String   @db.VarChar(100)
  status    String   // "active", "completed", "cancelled"
  winnerId  String?  @db.Uuid
  secondId  String?  @db.Uuid
  thirdId   String?  @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("tournaments")
}
